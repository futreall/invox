{
	"$schema": "https://esm.sh/wrangler/config-schema.json",
	"compatibility_date": "2025-12-17",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/index.server.ts",
	"workers_dev": true,
	"env": {
		"moderato": {
			"name": "invoice-moderato",
			"vars": {
				"VITE_TEMPO_ENV": "moderato"
			}
		}
	}
}
