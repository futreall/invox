{
	"name": "@tempo/apps",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "pnpm --filter invox dev",
		"build": "pnpm --filter invox build",
		"deploy": "pnpm --filter invox deploy",
